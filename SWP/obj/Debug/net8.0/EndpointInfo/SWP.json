  "components": {
    "schemas": {
      "AcademicTermRequestDto": {
        "required": [
          "endDate",
          "name",
          "startDate",
          "termCode"
        ],
        "type": "object",
        "properties": {
          "termCode": {
            "maxLength": 20,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9]+$",
            "type": "string"
          },
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      },
      "AddStudentRequestDto": {
        "required": [
          "studentId"
        ],
        "type": "object",
        "properties": {
          "studentId": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          },
          "tokenType": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "$ref": "#/components/schemas/UserInfoDto"
          }
        },
        "additionalProperties": false
      },
      "ClassRequestDto": {
        "required": [
          "academicTermId",
          "courseId",
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "maxLength": 20,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_-]+$",
            "type": "string"
          },
          "courseId": {
            "type": "string",
            "format": "uuid"
          },
          "academicTermId": {
            "type": "string",
            "format": "uuid"
          },
          "lecturerId": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "allowReviewAfterEnd": {
            "type": "boolean"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CourseRequestDto": {
        "required": [
          "code",
          "name"
        ],
        "type": "object",
        "properties": {
          "code": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9]+$",
            "type": "string"
          },
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string"
          },
          "description": {
